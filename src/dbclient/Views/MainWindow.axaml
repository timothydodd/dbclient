<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:dbclient.ViewModels"
        xmlns:views="using:dbclient.Views"
        x:Class="dbclient.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWin"
        Title="dbclient"
        Icon="avares://dbclient/Assets/app-icon.ico"
        Width="1400"
        Height="850"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="32"
        PointerMoved="Window_PointerMoved"
        PointerReleased="Window_PointerReleased">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewQueryTabCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseQueryTabCommand}" CommandParameter="{Binding SelectedConnectionTab.SelectedQueryTab}" />
        <KeyBinding Gesture="F5" Command="{Binding ExecuteQueryCommand}" />
        <KeyBinding Gesture="Ctrl+Return" Command="{Binding ExecuteQueryCommand}" />
        <KeyBinding Gesture="Ctrl+L" Command="{Binding ToggleConnectionPanelCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CancelQueryCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+F" Command="{Binding FormatQueryCommand}" />
        <KeyBinding Gesture="Ctrl+H" Command="{Binding ToggleHistoryPanelCommand}" />
    </Window.KeyBindings>

    <Panel>
        <DockPanel>
            <!-- Custom Title Bar -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource TitleBarBackground}"
                    Height="32">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                    <Image Grid.Column="0"
                           Source="avares://dbclient/Assets/app-icon.ico"
                           Width="18" Height="18"
                           Margin="10,0,4,0" VerticalAlignment="Center"/>

                    <Menu Grid.Column="1" VerticalAlignment="Center" Background="Transparent">
                        <MenuItem Header="_File">
                            <MenuItem Header="New _Connection..." Click="NewConnection_Click">
                                <MenuItem.Icon>
                                    <Path Data="M12 22v-5 M9 8V2 M15 8V2 M17 8a1 1 0 0 1 1 1v4a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1z"
                                          Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="_New Tab" Command="{Binding NewQueryTabCommand}" InputGesture="Ctrl+N">
                                <MenuItem.Icon>
                                    <Path Data="M12 5v14M5 12h14"
                                          Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5" StrokeLineCap="Round" Stretch="Uniform" Width="14" Height="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_Close Tab" Command="{Binding CloseQueryTabCommand}" CommandParameter="{Binding SelectedConnectionTab.SelectedQueryTab}" InputGesture="Ctrl+W">
                                <MenuItem.Icon>
                                    <Path Data="M18 6 6 18M6 6l12 12"
                                          Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5" StrokeLineCap="Round" Stretch="Uniform" Width="14" Height="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="E_xit" Click="Exit_Click" InputGesture="Alt+F4"/>
                        </MenuItem>
                        <MenuItem Header="_Query">
                            <MenuItem Header="_Execute" Command="{Binding ExecuteQueryCommand}" InputGesture="F5">
                                <MenuItem.Icon>
                                    <Path Data="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"
                                          Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_Cancel" Command="{Binding CancelQueryCommand}" InputGesture="Escape">
                                <MenuItem.Icon>
                                    <Path Data="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"
                                          Stroke="#ff5555" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="E_xplain" Command="{Binding ExplainQueryCommand}" InputGesture="Ctrl+E">
                                <MenuItem.Icon>
                                    <Path Data="M2 12a10 10 0 1 0 20 0a10 10 0 1 0-20 0 M12 16v-4 M12 8h.01"
                                          Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="_Format SQL" Command="{Binding FormatQueryCommand}" InputGesture="Ctrl+Shift+F">
                                <MenuItem.Icon>
                                    <Path Data="M21 5H3 M15 12H3 M17 19H3"
                                          Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="_History" x:Name="HistoryMenu" SubmenuOpened="HistoryMenu_SubmenuOpened">
                                <MenuItem.Icon>
                                    <Path Data="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8 M3 3v5h5 M12 7v5l4 2"
                                          Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform" Width="14" Height="14"/>
                                </MenuItem.Icon>
                                <MenuItem Header="(empty)" IsEnabled="False"/>
                            </MenuItem>
                        </MenuItem>
                        <MenuItem Header="_View">
                            <MenuItem Header="_Connection Panel" Command="{Binding ToggleConnectionPanelCommand}" InputGesture="Ctrl+L">
                                <MenuItem.Icon>
                                    <CheckBox IsChecked="{Binding IsConnectionPanelOpen}" BorderThickness="0" IsHitTestVisible="False"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_History Panel" Command="{Binding ToggleHistoryPanelCommand}" InputGesture="Ctrl+H">
                                <MenuItem.Icon>
                                    <CheckBox IsChecked="{Binding IsHistoryPanelOpen}" BorderThickness="0" IsHitTestVisible="False"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{Binding ThemeDisplayName}" Command="{Binding ToggleThemeCommand}" InputGesture="Ctrl+T"/>
                        </MenuItem>
                    </Menu>

                    <Border Grid.Column="2" Background="Transparent" PointerPressed="TitleBar_PointerPressed">
                        <TextBlock Text="dbclient" Foreground="{DynamicResource SecondaryText}" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Stretch">
                        <Button Click="Minimize_Click" Width="36" Height="28" Background="Transparent" BorderThickness="0"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                            <Path Data="M5 12h14" Stroke="{DynamicResource TitleBarForeground}" StrokeThickness="1" StrokeLineCap="Round" Stretch="Fill" Width="10" Height="1"/>
                        </Button>
                        <Button Click="MaximizeRestore_Click" Width="36" Height="28" Background="Transparent" BorderThickness="0"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                            <Path Data="M8 3H5a2 2 0 0 0-2 2v3 M21 8V5a2 2 0 0 0-2-2h-3 M3 16v3a2 2 0 0 0 2 2h3 M16 21h3a2 2 0 0 0 2-2v-3"
                                  Stroke="{DynamicResource TitleBarForeground}" StrokeThickness="1" StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform" Width="10" Height="10"/>
                        </Button>
                        <Button Click="Close_Click" Width="36" Height="28" Background="Transparent" BorderThickness="0"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Classes="close">
                            <Path Data="M18 6 6 18M6 6l12 12" Stroke="{DynamicResource TitleBarForeground}" StrokeThickness="1" StrokeLineCap="Round" Stretch="Uniform" Width="10" Height="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource TitleBarBackground}" Height="24" Padding="8,0">
                <Grid ColumnDefinitions="Auto,*">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                        <Path Data="M3 5a9 3 0 1 0 18 0a9 3 0 1 0-18 0 M3 5V19A9 3 0 0 0 21 19V5 M3 12A9 3 0 0 0 21 12"
                              Stroke="{DynamicResource AccentColor}" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform" Width="10" Height="10"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource StatusBarText}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding ExecutionTimeText}" Foreground="{DynamicResource StatusBarText}" FontSize="11"/>
                        <TextBlock Text="|" Foreground="{DynamicResource StatusBarSeparator}" FontSize="11"/>
                        <TextBlock Foreground="{DynamicResource StatusBarText}" FontSize="11">
                            <Run Text="Ln "/><Run Text="{Binding CursorLine}"/><Run Text=", Col "/><Run Text="{Binding CursorColumn}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0" MinWidth="0"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="0" MinWidth="0"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel (independent, no tabs over it) -->
                <views:ConnectionPanel x:Name="ConnectionPanelControl" Grid.Column="0"/>

                <GridSplitter x:Name="ConnectionSplitter" Grid.Column="1" Width="5"
                              Background="Transparent" ResizeDirection="Columns" IsVisible="False"/>

                <!-- Right side: Connection Tabs + Query Tabs + Editor + Results -->
                <Grid Grid.Column="2" x:Name="EditorResultsGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <!-- Query Sub-Tab Strip -->
                    <Border Grid.Row="0" Background="{DynamicResource TabStripBackground}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding NewQueryTabCommand}"
                                    ToolTip.Tip="New Tab (Ctrl+N)"
                                    MinHeight="30" Padding="8,4"
                                    VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                    Opacity="0.35" Classes="ghosttab">
                                <Path Stroke="{DynamicResource TabItemText}" StrokeThickness="1.5" StrokeLineCap="Round"
                                      Data="M12 5v14M5 12h14" Stretch="Uniform" Width="11" Height="11" VerticalAlignment="Center"/>
                            </Button>
                            <ListBox x:Name="TabStrip"
                                     ItemsSource="{Binding SelectedConnectionTab.QueryTabs}"
                                     SelectedItem="{Binding SelectedConnectionTab.SelectedQueryTab}"
                                     Background="Transparent" BorderThickness="0" Padding="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="vm:SessionTabViewModel">
                                        <Grid MinHeight="30" RowDefinitions="*,2" Tag="{Binding}"
                                              PointerPressed="TabItem_PointerPressed">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Close" Tag="{Binding}" Click="CloseTab_Click"/>
                                                    <MenuItem Header="Close Others" Tag="{Binding}" Click="CloseOthers_Click"/>
                                                    <MenuItem Header="Close to Right" Tag="{Binding}" Click="CloseToRight_Click"/>
                                                    <MenuItem Header="Close to Left" Tag="{Binding}" Click="CloseToLeft_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Rename..." Tag="{Binding}" Click="RenameTab_Click"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,4">
                                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="11"
                                                           DoubleTapped="TabTitle_DoubleTapped" Tag="{Binding}"/>
                                                <TextBlock Text="*" FontSize="11" Foreground="{DynamicResource AccentColor}"
                                                           VerticalAlignment="Center" Margin="3,0,0,0" IsVisible="{Binding IsDirty}"/>
                                                <Button Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CloseQueryTabCommand}"
                                                        CommandParameter="{Binding}"
                                                        Padding="0" Margin="6,0,0,0" Width="18" Height="18"
                                                        Background="Transparent" Opacity="0.3"
                                                        VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                        Classes="tabclose">
                                                    <Path Data="M18 6 6 18M6 6l12 12" Stroke="{DynamicResource TabCloseIconColor}"
                                                          StrokeThickness="2" StrokeLineCap="Round" Stretch="Uniform" Width="7" Height="7"/>
                                                </Button>
                                            </StackPanel>
                                            <Border Grid.Row="1" Background="{DynamicResource AccentColor}"
                                                    IsVisible="{Binding $parent[ListBoxItem].IsSelected}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- SQL Editor -->
                    <ContentControl Grid.Row="1" Content="{Binding SelectedConnectionTab.SelectedQueryTab}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="vm:SessionTabViewModel">
                                <views:EditorView DataContext="{Binding}" />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- Horizontal Splitter -->
                    <GridSplitter Grid.Row="2" Height="5" ResizeDirection="Rows" HorizontalAlignment="Stretch"/>

                    <!-- Results Panel -->
                    <views:ResultsPanel Grid.Row="3" DataContext="{Binding SelectedConnectionTab.SelectedQueryTab}"/>
                </Grid>

                <!-- History Splitter -->
                <GridSplitter x:Name="HistorySplitter" Grid.Column="3" Width="5"
                              Background="Transparent" ResizeDirection="Columns" IsVisible="False"/>

                <!-- History Panel -->
                <views:HistoryPanel x:Name="HistoryPanelControl" Grid.Column="4"/>
            </Grid>
        </DockPanel>

        <!-- Drag ghost overlay -->
        <Canvas x:Name="DragGhostCanvas" IsVisible="False" IsHitTestVisible="False">
            <Border x:Name="DragGhost" Background="{DynamicResource TabItemSelected}"
                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                    CornerRadius="3" Padding="8,4" Opacity="0.9">
                <TextBlock x:Name="DragGhostText" FontSize="11"/>
            </Border>
        </Canvas>
    </Panel>

    <Window.Styles>
        <Style Selector="Button.close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#ff5555"/>
        </Style>
        <Style Selector="StackPanel > Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource WindowControlHover}"/>
        </Style>
        <Style Selector="Button.tabclose:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </Window.Styles>
</Window>
