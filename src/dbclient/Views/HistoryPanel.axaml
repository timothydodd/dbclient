<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:dbclient.ViewModels"
             x:Class="dbclient.Views.HistoryPanel"
             x:DataType="vm:MainWindowViewModel">

    <Border Background="{DynamicResource PanelBackground}">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource PanelHeaderBackground}" Padding="10,6">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Click="Close_Click"
                            Background="Transparent" Padding="2" Width="22" Height="22" ToolTip.Tip="Close">
                        <Path Data="M18 6 6 18M6 6l12 12" Stroke="{DynamicResource MenuIconColor}"
                              StrokeThickness="1.5" StrokeLineCap="Round" Stretch="Uniform" Width="10" Height="10"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Data="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8 M3 3v5h5 M12 7v5l4 2"
                              Stroke="{DynamicResource AccentColor}" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round"
                              Stretch="Uniform" Width="12" Height="12" VerticalAlignment="Center"/>
                        <TextBlock Text="HISTORY" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PanelHeaderText}" Opacity="0.7" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Search box -->
            <Border DockPanel.Dock="Top" Padding="6,6,6,4">
                <TextBox x:Name="SearchBox" Watermark="Search history..." FontSize="11"
                         TextChanged="SearchBox_TextChanged"/>
            </Border>

            <!-- History list -->
            <ScrollViewer x:Name="HistoryScroll">
                <StackPanel x:Name="HistoryList" Spacing="1" Margin="2,0"/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
