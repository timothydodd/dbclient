<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:converters="using:Avalonia.Controls.Converters"
        x:Class="dbclient.Themes.LightTheme">

    <Styles.Resources>
        <!-- Title bar / Status bar -->
        <SolidColorBrush x:Key="TitleBarBackground" Color="#e8e8e8"/>
        <SolidColorBrush x:Key="TitleBarForeground" Color="#1e1e1e"/>
        <SolidColorBrush x:Key="StatusBarText" Color="#6b7280"/>
        <SolidColorBrush x:Key="StatusBarSeparator" Color="#d1d5db"/>
        <SolidColorBrush x:Key="WindowControlHover" Color="#d1d5db"/>

        <!-- Accent / UI -->
        <SolidColorBrush x:Key="AccentColor" Color="#2563eb"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#6b7280"/>
        <SolidColorBrush x:Key="WarningColor" Color="#d97706"/>

        <!-- Tab strip -->
        <SolidColorBrush x:Key="TabStripBackground" Color="#e8e8e8"/>
        <SolidColorBrush x:Key="TabItemBackground" Color="#e8e8e8"/>
        <SolidColorBrush x:Key="TabItemHover" Color="#d1d5db"/>
        <SolidColorBrush x:Key="TabItemSelected" Color="#ffffff"/>
        <SolidColorBrush x:Key="TabItemSelectedText" Color="#111827"/>
        <SolidColorBrush x:Key="TabItemText" Color="#6b7280"/>

        <!-- Panels -->
        <SolidColorBrush x:Key="PanelBackground" Color="#f3f4f6"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#d1d5db"/>
        <SolidColorBrush x:Key="PanelHeaderBackground" Color="#e8e8e8"/>
        <SolidColorBrush x:Key="PanelHeaderText" Color="#111827"/>

        <!-- Icons -->
        <SolidColorBrush x:Key="MenuIconColor" Color="#4b5563"/>
        <SolidColorBrush x:Key="TabCloseIconColor" Color="#374151"/>

        <!-- Completion window -->
        <SolidColorBrush x:Key="CompletionBackground" Color="#ffffff"/>
        <SolidColorBrush x:Key="CompletionBorder" Color="#d1d5db"/>
        <SolidColorBrush x:Key="CompletionSelected" Color="#e0e7ff"/>
        <SolidColorBrush x:Key="KeywordColor" Color="#7c3aed"/>
        <SolidColorBrush x:Key="TableColor" Color="#0369a1"/>
        <SolidColorBrush x:Key="ColumnColor" Color="#15803d"/>
        <SolidColorBrush x:Key="AliasColor" Color="#b45309"/>

        <!-- Results grid -->
        <SolidColorBrush x:Key="ResultsBackground" Color="#ffffff"/>
        <SolidColorBrush x:Key="ResultsHeaderBackground" Color="#f3f4f6"/>
        <SolidColorBrush x:Key="ResultsGridLine" Color="#e5e7eb"/>

        <!-- Data type colors -->
        <SolidColorBrush x:Key="DataTypeNumeric" Color="#a35f00"/>
        <SolidColorBrush x:Key="DataTypeDate" Color="#0f6b8a"/>
        <SolidColorBrush x:Key="DataTypeBoolean" Color="#6f42c1"/>
        <SolidColorBrush x:Key="DataTypeBinary" Color="#6b7280"/>
        <SolidColorBrush x:Key="DataTypeNull" Color="#9ca3af"/>

        <!-- Message colors -->
        <SolidColorBrush x:Key="ErrorColor" Color="#dc2626"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#16a34a"/>
        <SolidColorBrush x:Key="InfoColor" Color="#6b7280"/>
        <SolidColorBrush x:Key="NormalText" Color="#111827"/>
        <SolidColorBrush x:Key="MutedText" Color="#9ca3af"/>
        <SolidColorBrush x:Key="CompletionText" Color="#111827"/>
        <SolidColorBrush x:Key="CompletionDescText" Color="#6b7280"/>

        <!-- Tree node colors: unified high-contrast normal text, db distinct -->
        <SolidColorBrush x:Key="TreeNodeColor" Color="#111827"/>
        <SolidColorBrush x:Key="DatabaseNodeColor" Color="#1d4ed8"/>

        <!-- Connection tree -->
        <SolidColorBrush x:Key="TreeBackground" Color="#f3f4f6"/>
        <SolidColorBrush x:Key="SearchBoxBackground" Color="#1f2937"/>
        <SolidColorBrush x:Key="SearchBoxFocusBorder" Color="#4b5563"/>

        <!-- TreeView indent per nesting level (must redefine converter to pick up custom value) -->
        <x:Double x:Key="TreeViewItemIndent">2</x:Double>
        <converters:MarginMultiplierConverter Indent="{StaticResource TreeViewItemIndent}" Left="True" x:Key="TreeViewItemLeftMarginConverter"/>

        <!-- TreeView chevron arrow color: high-contrast accent, distinct from text -->
        <SolidColorBrush x:Key="TreeViewItemForeground" Color="#2563eb"/>
        <SolidColorBrush x:Key="TreeViewItemForegroundPointerOver" Color="#1e40af"/>
        <SolidColorBrush x:Key="TreeViewItemForegroundPressed" Color="#1e40af"/>
        <SolidColorBrush x:Key="TreeViewItemForegroundSelected" Color="#1e40af"/>
        <SolidColorBrush x:Key="TreeViewItemForegroundSelectedPointerOver" Color="#1e40af"/>
        <SolidColorBrush x:Key="TreeViewItemForegroundSelectedPressed" Color="#1e40af"/>

        <!-- Menu / ContextMenu (Fluent theme resources) -->
        <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="#ffffff"/>
        <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="#d1d5db"/>
        <SolidColorBrush x:Key="MenuFlyoutItemBackground" Color="Transparent"/>
        <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver" Color="#e5e7eb"/>
        <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPressed" Color="#d1d5db"/>
        <SolidColorBrush x:Key="MenuFlyoutItemBackgroundDisabled" Color="Transparent"/>
        <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="#111827"/>
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="#111827"/>
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed" Color="#111827"/>
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundDisabled" Color="#9ca3af"/>
        <SolidColorBrush x:Key="MenuFlyoutSubItemChevron" Color="#6b7280"/>
        <SolidColorBrush x:Key="MenuFlyoutSubItemChevronPointerOver" Color="#111827"/>
        <SolidColorBrush x:Key="MenuFlyoutSubItemChevronSubMenuOpened" Color="#111827"/>
    </Styles.Resources>

    <Style Selector="Window">
        <Setter Property="Background" Value="#f0f0f0"/>
        <Setter Property="Foreground" Value="#111827"/>
    </Style>

    <Style Selector="ae|TextEditor">
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="Foreground" Value="#1e1e1e"/>
        <Setter Property="LineNumbersForeground" Value="#9ca3af"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="ShowLineNumbers" Value="True"/>
        <Setter Property="Padding" Value="8,10,10,10"/>
        <Setter Property="SearchResultsBrush" Value="#40fbbf24"/>
    </Style>

    <Style Selector="Button">
        <Setter Property="Background" Value="#e5e7eb"/>
        <Setter Property="Foreground" Value="#111827"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#e5e7eb"/>
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#d1d5db"/>
    </Style>

    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#c0c4cb"/>
    </Style>

    <Style Selector="Menu">
        <Setter Property="Background" Value="#e8e8e8"/>
        <Setter Property="Foreground" Value="#111827"/>
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#111827"/>
    </Style>

    <Style Selector="MenuItem /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#d1d5db"/>
    </Style>

    <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#d1d5db"/>
    </Style>

    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#d1d5db"/>
    </Style>

    <!-- Menu dropdown popup background -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#d1d5db"/>
        <Setter Property="Padding" Value="0,4"/>
    </Style>

    <Style Selector="MenuFlyoutPresenter /template/ Border">
        <Setter Property="Background" Value="#ffffff"/>
    </Style>

    <Style Selector="MenuItem /template/ Popup > Border">
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#d1d5db"/>
        <Setter Property="Padding" Value="0,4"/>
    </Style>

    <!-- Scrollbar -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="#e5e7eb"/>
        <Setter Property="AllowAutoHide" Value="False"/>
        <Style.Resources>
            <TransformOperations x:Key="VerticalSmallScrollThumbScaleTransform">none</TransformOperations>
            <TransformOperations x:Key="HorizontalSmallScrollThumbScaleTransform">none</TransformOperations>
        </Style.Resources>
    </Style>

    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#9ca3af"/>
        <Setter Property="MinWidth" Value="10"/>
        <Setter Property="MinHeight" Value="10"/>
        <Setter Property="RenderTransform" Value="none"/>
    </Style>

    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="14"/>
    </Style>

    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="14"/>
    </Style>

    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="#6b7280"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="Foreground" Value="#111827"/>
        <Setter Property="BorderBrush" Value="#d1d5db"/>
        <Setter Property="CaretBrush" Value="#111827"/>
        <Setter Property="SelectionBrush" Value="#93c5fd"/>
    </Style>

    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="#2563eb"/>
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="#111827"/>
    </Style>

    <!-- TreeView -->
    <Style Selector="TreeView">
        <Setter Property="Background" Value="#f3f4f6"/>
    </Style>

    <Style Selector="TreeViewItem">
        <Setter Property="Foreground" Value="#111827"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="TreeViewItem /template/ Border#PART_LayoutRoot">
        <Setter Property="MinHeight" Value="20"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#302563eb"/>
    </Style>

    <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#15111827"/>
    </Style>

    <Style Selector="TreeViewItem:selected:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#402563eb"/>
    </Style>

    <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Compact tree chevron -->
    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="14"/>
    </Style>

    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron /template/ Path">
        <Setter Property="Width" Value="7"/>
        <Setter Property="Height" Value="7"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>

    <!-- Connection tab strip -->
    <Style Selector="ListBox#ConnectionTabStrip">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem">
        <Setter Property="Background" Value="#e8e8e8"/>
        <Setter Property="Foreground" Value="#6b7280"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem /template/ ContentPresenter">
        <Setter Property="Background" Value="#e8e8e8"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#d1d5db"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#f3f4f6"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="#111827"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem TextBlock">
        <Setter Property="Foreground" Value="#6b7280"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="#111827"/>
    </Style>

    <!-- Query tab strip -->
    <Style Selector="ListBox#TabStrip">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem">
        <Setter Property="Background" Value="{DynamicResource TabItemBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TabItemText}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemBackground}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemHover}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemSelected}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedText}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TabItemText}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedText}"/>
    </Style>

    <!-- Ghost tab button -->
    <Style Selector="Button.ghosttab">
        <Setter Property="Background" Value="{DynamicResource TabItemBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TabItemText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style Selector="Button.ghosttab /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemBackground}"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.ghosttab:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemHover}"/>
    </Style>

    <!-- DataGrid -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="RowBackground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#e5e7eb"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#f0f0f0"/>
        <Setter Property="VerticalGridLinesBrush" Value="#f0f0f0"/>
        <Setter Property="RowHeight" Value="24"/>
    </Style>
    <Style Selector="DataGrid ScrollBar">
        <Setter Property="AllowAutoHide" Value="False"/>
    </Style>
    <Style Selector="DataGrid /template/ Rectangle#PART_BottomRightCorner">
        <Setter Property="Fill" Value="#e5e7eb"/>
    </Style>
    <Style Selector="DataGrid /template/ ScrollViewer /template/ Panel#PART_ScrollBarsSeparator">
        <Setter Property="Background" Value="#e5e7eb"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="#f3f4f6"/>
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="SeparatorBrush" Value="#d1d5db"/>
        <Setter Property="AreSeparatorsVisible" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="*,4">
                    <ContentPresenter Grid.Column="0"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="4,2"/>
                    <Thumb Grid.Column="1"
                           Name="PART_ColumnHeaderGripper"
                           Background="Transparent"
                           Cursor="SizeWestEast"
                           Width="4"/>
                    <Border Grid.Column="0" Grid.ColumnSpan="2"
                            BorderBrush="#d1d5db"
                            BorderThickness="0,0,1,1"/>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="DataGridRow">
        <Setter Property="Foreground" Value="#1e1e1e"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MinHeight" Value="22"/>
    </Style>

    <Style Selector="DataGridCell">
        <Setter Property="Foreground" Value="#1e1e1e"/>
        <Setter Property="Padding" Value="6,1"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="DataGridCell TextBlock">
        <Setter Property="Foreground" Value="#1e1e1e"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="DataGridCell ContentPresenter">
        <Setter Property="Foreground" Value="#1e1e1e"/>
    </Style>

    <!-- Current cell highlight -->
    <Style Selector="DataGridCell:current">
        <Setter Property="Background" Value="#dde8ff"/>
    </Style>

    <!-- GridSplitter -->
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="#d1d5db"/>
    </Style>

    <Style Selector="GridSplitter:pointerover">
        <Setter Property="Background" Value="#9ca3af"/>
    </Style>

    <Style Selector="Separator">
        <Setter Property="Background" Value="#e5e7eb"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <!-- Menu separators -->
    <Style Selector="MenuItem > Separator">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="Transparent"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="4,4"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderBrush" Value="#d1d5db"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="MenuItem > Separator /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="BorderBrush" Value="#d1d5db"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="ContextMenu Separator">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="4,4"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderBrush" Value="#d1d5db"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="ContextMenu Separator /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="BorderBrush" Value="#d1d5db"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>
</Styles>
