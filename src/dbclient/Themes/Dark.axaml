<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="using:AvaloniaEdit"
        x:Class="dbclient.Themes.DarkTheme">

    <Styles.Resources>
        <!-- Title bar / Status bar -->
        <SolidColorBrush x:Key="TitleBarBackground" Color="#1b1b1b"/>
        <SolidColorBrush x:Key="TitleBarForeground" Color="#DBE6EC"/>
        <SolidColorBrush x:Key="StatusBarText" Color="#888888"/>
        <SolidColorBrush x:Key="StatusBarSeparator" Color="#4a4a4a"/>
        <SolidColorBrush x:Key="WindowControlHover" Color="#3a3a3a"/>

        <!-- Accent / UI -->
        <SolidColorBrush x:Key="AccentColor" Color="#558cb1"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#888888"/>
        <SolidColorBrush x:Key="WarningColor" Color="#D2BE3F"/>

        <!-- Tab strip -->
        <SolidColorBrush x:Key="TabStripBackground" Color="#262626"/>
        <SolidColorBrush x:Key="TabItemBackground" Color="#262626"/>
        <SolidColorBrush x:Key="TabItemHover" Color="#3a3a3a"/>
        <SolidColorBrush x:Key="TabItemSelected" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TabItemSelectedText" Color="#DBE6EC"/>
        <SolidColorBrush x:Key="TabItemText" Color="#888888"/>

        <!-- Panels -->
        <SolidColorBrush x:Key="PanelBackground" Color="#262626"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#4a4a4a"/>
        <SolidColorBrush x:Key="PanelHeaderBackground" Color="#1b1b1b"/>
        <SolidColorBrush x:Key="PanelHeaderText" Color="#DBE6EC"/>

        <!-- Icons -->
        <SolidColorBrush x:Key="MenuIconColor" Color="#888888"/>
        <SolidColorBrush x:Key="TabCloseIconColor" Color="#DBE6EC"/>

        <!-- Completion window -->
        <SolidColorBrush x:Key="CompletionBackground" Color="#262626"/>
        <SolidColorBrush x:Key="CompletionBorder" Color="#4a4a4a"/>
        <SolidColorBrush x:Key="CompletionSelected" Color="#3a3a3a"/>
        <SolidColorBrush x:Key="KeywordColor" Color="#558cb1"/>
        <SolidColorBrush x:Key="TableColor" Color="#2B91AF"/>
        <SolidColorBrush x:Key="ColumnColor" Color="#7aba7a"/>
        <SolidColorBrush x:Key="AliasColor" Color="#D2BE3F"/>

        <!-- Results grid -->
        <SolidColorBrush x:Key="ResultsBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="ResultsHeaderBackground" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="ResultsGridLine" Color="#3a3a3a"/>

        <!-- Message colors -->
        <SolidColorBrush x:Key="ErrorColor" Color="#ff5555"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#50fa7b"/>
        <SolidColorBrush x:Key="InfoColor" Color="#6272a4"/>
        <SolidColorBrush x:Key="NormalText" Color="#DBE6EC"/>
        <SolidColorBrush x:Key="MutedText" Color="#888888"/>
        <SolidColorBrush x:Key="CompletionText" Color="#DBE6EC"/>
        <SolidColorBrush x:Key="CompletionDescText" Color="#888888"/>

        <!-- Tree node colors -->
        <SolidColorBrush x:Key="DatabaseNodeColor" Color="#558cb1"/>
        <SolidColorBrush x:Key="FolderNodeColor" Color="#888888"/>
        <SolidColorBrush x:Key="TableNodeColor" Color="#2B91AF"/>
        <SolidColorBrush x:Key="ViewNodeColor" Color="#7aba7a"/>
        <SolidColorBrush x:Key="ProcNodeColor" Color="#D2BE3F"/>
        <SolidColorBrush x:Key="ColumnNodeColor" Color="#c7c7c7"/>
        <SolidColorBrush x:Key="DefaultNodeColor" Color="#DBE6EC"/>

        <!-- Connection tree -->
        <SolidColorBrush x:Key="TreeBackground" Color="#262626"/>
    </Styles.Resources>

    <Style Selector="Window">
        <Setter Property="Background" Value="#2a2a2a"/>
        <Setter Property="Foreground" Value="#DBE6EC"/>
    </Style>

    <Style Selector="ae|TextEditor">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#DBE6EC"/>
        <Setter Property="LineNumbersForeground" Value="#595959"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="ShowLineNumbers" Value="True"/>
        <Setter Property="Padding" Value="8,10,10,10"/>
        <Setter Property="SearchResultsBrush" Value="#3A558cb1"/>
    </Style>

    <Style Selector="Button">
        <Setter Property="Background" Value="#3a3a3a"/>
        <Setter Property="Foreground" Value="#DBE6EC"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#3a3a3a"/>
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#4a4a4a"/>
    </Style>

    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#535353"/>
    </Style>

    <Style Selector="Menu">
        <Setter Property="Background" Value="#1b1b1b"/>
        <Setter Property="Foreground" Value="#DBE6EC"/>
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#DBE6EC"/>
    </Style>

    <Style Selector="MenuItem /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#3a3a3a"/>
    </Style>

    <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#3a3a3a"/>
    </Style>

    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="#262626"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
    </Style>

    <!-- Menu dropdown popup background -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="#1b1b1b"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
        <Setter Property="Padding" Value="0,4"/>
    </Style>

    <Style Selector="MenuFlyoutPresenter /template/ Border">
        <Setter Property="Background" Value="#1b1b1b"/>
    </Style>

    <Style Selector="MenuItem /template/ Popup > Border">
        <Setter Property="Background" Value="#1b1b1b"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
        <Setter Property="Padding" Value="0,4"/>
    </Style>

    <!-- Scrollbar -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="#262626"/>
        <Setter Property="AllowAutoHide" Value="False"/>
    </Style>

    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#4a4a4a"/>
        <Setter Property="MinWidth" Value="10"/>
        <Setter Property="MinHeight" Value="10"/>
    </Style>

    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="14"/>
    </Style>

    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="14"/>
    </Style>

    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="#6a6a6a"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#DBE6EC"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
        <Setter Property="CaretBrush" Value="#DBE6EC"/>
        <Setter Property="SelectionBrush" Value="#558cb1"/>
    </Style>

    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="#558cb1"/>
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="#DBE6EC"/>
    </Style>

    <!-- TreeView -->
    <Style Selector="TreeView">
        <Setter Property="Background" Value="#262626"/>
    </Style>

    <Style Selector="TreeViewItem">
        <Setter Property="Foreground" Value="#DBE6EC"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="TreeViewItem /template/ Border#PART_LayoutRoot">
        <Setter Property="MinHeight" Value="20"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#30558cb1"/>
    </Style>

    <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#20DBE6EC"/>
    </Style>

    <Style Selector="TreeViewItem:selected:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#40558cb1"/>
    </Style>

    <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Compact tree chevron -->
    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="14"/>
    </Style>

    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron /template/ Path">
        <Setter Property="Width" Value="7"/>
        <Setter Property="Height" Value="7"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Fill" Value="#595959"/>
    </Style>

    <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron:pointerover /template/ Path">
        <Setter Property="Fill" Value="#DBE6EC"/>
    </Style>

    <!-- Connection tab strip -->
    <Style Selector="ListBox#ConnectionTabStrip">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem">
        <Setter Property="Background" Value="#262626"/>
        <Setter Property="Foreground" Value="#888888"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem /template/ ContentPresenter">
        <Setter Property="Background" Value="#262626"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#3a3a3a"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#1E1E1E"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="#DBE6EC"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem TextBlock">
        <Setter Property="Foreground" Value="#888888"/>
    </Style>

    <Style Selector="ListBox#ConnectionTabStrip ListBoxItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="#DBE6EC"/>
    </Style>

    <!-- Query tab strip -->
    <Style Selector="ListBox#TabStrip">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem">
        <Setter Property="Background" Value="{DynamicResource TabItemBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TabItemText}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemBackground}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemHover}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemSelected}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedText}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TabItemText}"/>
    </Style>

    <Style Selector="ListBox#TabStrip ListBoxItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedText}"/>
    </Style>

    <!-- Ghost tab button -->
    <Style Selector="Button.ghosttab">
        <Setter Property="Background" Value="{DynamicResource TabItemBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TabItemText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style Selector="Button.ghosttab /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemBackground}"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.ghosttab:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource TabItemHover}"/>
    </Style>

    <!-- DataGrid -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="RowBackground" Value="#1E1E1E"/>
        <Setter Property="BorderBrush" Value="#3a3a3a"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#333333"/>
        <Setter Property="VerticalGridLinesBrush" Value="#333333"/>
        <Setter Property="RowHeight" Value="24"/>
    </Style>

    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="#2a2a2a"/>
        <Setter Property="Foreground" Value="#DBE6EC"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="SeparatorBrush" Value="#4a4a4a"/>
        <Setter Property="AreSeparatorsVisible" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="*,4">
                    <ContentPresenter Grid.Column="0"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="4,2"/>
                    <Thumb Grid.Column="1"
                           Name="PART_ColumnHeaderGripper"
                           Background="Transparent"
                           Cursor="SizeWestEast"
                           Width="4"/>
                    <Border Grid.Column="0" Grid.ColumnSpan="2"
                            BorderBrush="#3a3a3a"
                            BorderThickness="0,0,1,1"/>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="DataGridRow">
        <Setter Property="Foreground" Value="#DBE6EC"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MinHeight" Value="22"/>
    </Style>

    <Style Selector="DataGridCell">
        <Setter Property="Foreground" Value="#DBE6EC"/>
        <Setter Property="Padding" Value="6,1"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="DataGridCell TextBlock">
        <Setter Property="Foreground" Value="#DBE6EC"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="DataGridCell ContentPresenter">
        <Setter Property="Foreground" Value="#DBE6EC"/>
    </Style>

    <!-- GridSplitter -->
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="#3a3a3a"/>
    </Style>

    <Style Selector="GridSplitter:pointerover">
        <Setter Property="Background" Value="#4a4a4a"/>
    </Style>

    <Style Selector="Separator">
        <Setter Property="Background" Value="#3a3a3a"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <!-- Menu separators: transparent background, thin line only -->
    <Style Selector="MenuItem > Separator">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="Transparent"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="4,4"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="MenuItem > Separator /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="ContextMenu Separator">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="4,4"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="ContextMenu Separator /template/ Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="BorderBrush" Value="#4a4a4a"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>
</Styles>
